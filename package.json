{
  "name": "k3lpoke-obs-tools",
  "version": "0.1.2",
  "description": "K3lPoke OBS Tools — Twitch clip queue, overlay, and scene management",
  "author": "K3lPoke",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder --win",
    "index": "node .claude/gen-index.js"
  },
  "build": {
    "appId": "com.k3lpoke.obs-tools",
    "productName": "K3lPoke OBS Tools",
    "directories": {
      "output": "dist"
    },
    "electronDist": "./node_modules/electron/dist",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "src/overlay",
        "to": "overlay"
      },
      {
        "from": "src/dock",
        "to": "dock"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "K3lpoke",
      "repo": "twitch-clips-k3lpoke"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "K3lPoke OBS Tools"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "obs-websocket-js": "^5.0.3",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "icojs": "^0.22.1",
    "lucide-react": "^0.395.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "to-ico": "^1.1.5"
  }
}
